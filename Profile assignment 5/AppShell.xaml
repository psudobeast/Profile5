<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Profile_assignment_5.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:view="clr-namespace:Profile_assignment_5.View"
    FlyoutBehavior="Flyout">

    <FlyoutItem Title="Shopping" Icon="dotnet_bot.png">
        <ShellContent
            Title="Shopping List"
            ContentTemplate="{DataTemplate view:ShoppingListPage}"
            Route="ShoppingListPage" />
    </FlyoutItem>

    <FlyoutItem Title="Cart" Icon="dotnet_bot.png">
        <ShellContent
            Title="Shopping Cart"
            ContentTemplate="{DataTemplate view:ShoppingCartPage}"
            Route="ShoppingCartPage" />
    </FlyoutItem>

    <FlyoutItem Title="Profile" Icon="dotnet_bot.png">
        <ShellContent
            Title="My Profile"
            ContentTemplate="{DataTemplate view:ProfilePage}"
            Route="ProfilePage" />
    </FlyoutItem>

</Shell>
