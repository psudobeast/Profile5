<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Profile_assignment_5.View.ProfilePage"
             Title="ProfilePage"
             BackgroundColor="#F5F6FA"
             >



    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="25">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                <Grid HeightRequest="140" WidthRequest="140">
                    <Border StrokeShape="RoundRectangle 70"
                            StrokeThickness="0"
                            HeightRequest="130"
                            WidthRequest="130"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1" />
                        </Border.Shadow>

                        <Image x:Name="ProfileImage"
                               Source="profile_icon.png"
                               Aspect="AspectFill">
                            <Image.Clip>
                                <EllipseGeometry Center="65,65" RadiusX="65" RadiusY="65" />
                            </Image.Clip>
                        </Image>
                    </Border>

                    <ImageButton Source="camera_icon.png" 
                                 BackgroundColor="#2196F3"
                                 CornerRadius="18"
                                 HeightRequest="36"
                                 WidthRequest="36"
                                 Padding="8"
                                 HorizontalOptions="End"
                                 VerticalOptions="End"
                                 Clicked="OnChangePictureClicked" />
                </Grid>

            </VerticalStackLayout>

            <Border Padding="20" 
                    StrokeThickness="0" 
                    BackgroundColor="White"
                    HorizontalOptions="Fill">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="15" Opacity="0.05" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">
                    <Label Text="Personal Information" FontSize="16" FontAttributes="Bold" TextColor="#2D3436" />

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Name" FontSize="13" TextColor="#B2BEC3" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E1E8EE" BackgroundColor="#F9FBFC">
                            <Grid ColumnDefinitions="40, *">
                                <Image Source="name_icon.png" WidthRequest="50" Opacity="0.6" Grid.Column="0"/>
                                <Entry x:Name="NameEntry" Placeholder="First Name" TextColor="#2D3436" Grid.Column="1" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Surname" FontSize="13" TextColor="#B2BEC3" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E1E8EE" BackgroundColor="#F9FBFC">
                            <Grid ColumnDefinitions="40, *">
                                <Image Source="surname_icon.png" WidthRequest="50" Opacity="0.6" Grid.Column="0"/>
                                <Entry x:Name="SurnameEntry" Placeholder="Last Name" TextColor="#2D3436" Grid.Column="1" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Email Address" FontSize="13" TextColor="#B2BEC3" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E1E8EE" BackgroundColor="#F9FBFC">
                            <Grid ColumnDefinitions="40, *">
                                <Image Source="email_icon.png" WidthRequest="50" Opacity="0.6" Grid.Column="0"/>
                                <Entry x:Name="EmailEntry" Keyboard="Email" Placeholder="example@quantixa.com" TextColor="#2D3436" Grid.Column="1" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Short Bio" FontSize="13" TextColor="#B2BEC3" Margin="5,0"/>
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E1E8EE" BackgroundColor="#F9FBFC">
                            <Editor x:Name="BioEditor" Placeholder="Write a bit about yourself..." AutoSize="TextChanges" MinimumHeightRequest="80" TextColor="#2D3436" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Save Changes" 
                    BackgroundColor="#2196F3" 
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="15"
                    Clicked="OnSaveClicked">
                <Button.Shadow>
                    <Shadow Brush="#2196F3" Offset="0,8" Radius="12" Opacity="0.3" />
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>