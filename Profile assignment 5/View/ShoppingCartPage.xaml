<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Profile_assignment_5.View.ShoppingCartPage"
             Title="Shopping Cart"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="10">

        <!-- Header -->
        <Border Grid.Row="0" 
                Padding="15" 
                Margin="5"
                StrokeThickness="0" 
                BackgroundColor="#2196F3">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" 
                       Text="My Shopping Cart" 
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>

                <Button Grid.Column="1"
                        Text="Clear Cart"
                        BackgroundColor="White"
                        TextColor="#E74C3C"
                        CornerRadius="10"
                        Padding="15,5"
                        Clicked="OnClearCartClicked"/>
            </Grid>
        </Border>

        <!-- Cart Items List -->
        <CollectionView x:Name="CartItemsCollection" 
                        Grid.Row="1"
                        Margin="5">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" 
                            StrokeThickness="0" 
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.1" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="80,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15">

                            <!-- Product Image -->
                            <Border Grid.Column="0" 
                                    Grid.RowSpan="3"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1"
                                    Stroke="#E1E8EE"
                                    BackgroundColor="#F9FBFC">
                                <Image Source="{Binding Item.ImageUrl}"
                                       Aspect="AspectFit"
                                       WidthRequest="70"
                                       HeightRequest="70"/>
                            </Border>

                            <!-- Product Name -->
                            <Label Grid.Column="1" 
                                   Grid.Row="0"
                                   Text="{Binding Item.Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#2D3436"/>

                            <!-- Product Price -->
                            <Label Grid.Column="1" 
                                   Grid.Row="1"
                                   Text="{Binding Item.Price, StringFormat='${0:F2} each'}"
                                   FontSize="14"
                                   TextColor="#00B894"/>

                            <!-- Quantity Controls -->
                            <HorizontalStackLayout Grid.Column="1" 
                                                   Grid.Row="2" 
                                                   Spacing="10">
                                <Label Text="Quantity:"
                                       FontSize="14"
                                       TextColor="#636E72"
                                       VerticalOptions="Center"/>

                                <Button Text="-"
                                        BackgroundColor="#E74C3C"
                                        TextColor="White"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        CornerRadius="5"
                                        Padding="0"
                                        Clicked="OnDecreaseQuantityClicked"
                                        CommandParameter="{Binding .}"/>

                                <Label Text="{Binding Cart.Quantity}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       WidthRequest="30"
                                       HorizontalTextAlignment="Center"
                                       VerticalOptions="Center"/>

                                <Button Text="+"
                                        BackgroundColor="#00B894"
                                        TextColor="White"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        CornerRadius="5"
                                        Padding="0"
                                        Clicked="OnIncreaseQuantityClicked"
                                        CommandParameter="{Binding .}"/>
                            </HorizontalStackLayout>

                            <!-- Remove Button -->
                            <Button Grid.Column="2" 
                                    Grid.RowSpan="3"
                                    Text="Remove"
                                    BackgroundColor="#E74C3C"
                                    TextColor="White"
                                    CornerRadius="10"
                                    VerticalOptions="Center"
                                    Padding="15,10"
                                    Clicked="OnRemoveItemClicked"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" 
                                     VerticalOptions="Center"
                                     Spacing="15">
                    <Label Text="🛒"
                           FontSize="64"
                           HorizontalOptions="Center"/>
                    <Label Text="Your cart is empty"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#636E72"
                           HorizontalOptions="Center"/>
                    <Label Text="Add items from the shopping list"
                           FontSize="14"
                           TextColor="#B2BEC3"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Total Section -->
        <Border Grid.Row="2" 
                Padding="15" 
                Margin="5"
                StrokeThickness="0" 
                BackgroundColor="White">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" 
                       Text="Total:"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#2D3436"
                       VerticalOptions="Center"/>

                <Label Grid.Column="1"
                       x:Name="TotalLabel"
                       Text="$0.00"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#00B894"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Bottom Navigation -->
        <Border Grid.Row="3" 
                Padding="10" 
                Margin="5"
                StrokeThickness="0" 
                BackgroundColor="White">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <Button Text="Back to Shopping List"
                    BackgroundColor="#6C5CE7"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnBackToShoppingClicked"/>
        </Border>
    </Grid>
</ContentPage>
