<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Profile_assignment_5.View.ShoppingListPage"
             Title="Shopping List"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="Auto,*,Auto" Padding="10">

        <!-- Header -->
        <Border Grid.Row="0" 
                Padding="15" 
                Margin="5"
                StrokeThickness="0" 
                BackgroundColor="#2196F3">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" 
                       Text="Available Products" 
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>

                <Button Grid.Column="1"
                        Text="View Cart"
                        BackgroundColor="White"
                        TextColor="#2196F3"
                        CornerRadius="10"
                        Padding="15,5"
                        Clicked="OnViewCartClicked"/>
            </Grid>
        </Border>

        <!-- Shopping Items List -->
        <CollectionView x:Name="ShoppingItemsCollection" 
                        Grid.Row="1"
                        Margin="5">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" 
                            StrokeThickness="0" 
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>

                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.1" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="80,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15">

                            <!-- Product Image -->
                            <Border Grid.Column="0" 
                                    Grid.RowSpan="3"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1"
                                    Stroke="#E1E8EE"
                                    BackgroundColor="#F9FBFC">
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFit"
                                       WidthRequest="70"
                                       HeightRequest="70"/>
                            </Border>

                            <!-- Product Name -->
                            <Label Grid.Column="1" 
                                   Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#2D3436"/>

                            <!-- Product Description -->
                            <Label Grid.Column="1" 
                                   Grid.Row="1"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="#636E72"/>

                            <!-- Price and Stock -->
                            <HorizontalStackLayout Grid.Column="1" 
                                                   Grid.Row="2" 
                                                   Spacing="15">
                                <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#00B894"/>

                                <Label Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                       FontSize="14"
                                       TextColor="#636E72"/>
                            </HorizontalStackLayout>

                            <!-- Add to Cart Button -->
                            <Button Grid.Column="2" 
                                    Grid.RowSpan="3"
                                    Text="Add to Cart"
                                    BackgroundColor="#2196F3"
                                    TextColor="White"
                                    CornerRadius="10"
                                    VerticalOptions="Center"
                                    Padding="15,10"
                                    Clicked="OnAddToCartClicked"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom Navigation -->
        <Border Grid.Row="2" 
                Padding="10" 
                Margin="5"
                StrokeThickness="0" 
                BackgroundColor="White">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>

            <Button Text="Go to Profile"
                    BackgroundColor="#6C5CE7"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    Clicked="OnGoToProfileClicked"/>
        </Border>
    </Grid>
</ContentPage>
